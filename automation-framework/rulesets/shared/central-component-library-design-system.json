  "design_rules": {
    "source_of_truth": {
      "primary_sources": [
        "central-component-library/src/index.tsx",
        "central-component-library/stories/**",
        "central-component-library/src/theme/index.ts",
        "central-component-library/src/theme/themeTokens.ts",
        "central-component-library/src/utils/DesignVariantsUtils.tsx"
      ],
      "priority": [
        "Direct Storybook story target",
        "Theme and token definitions",
        "Public component export contract",
        "Approved product baseline only if Storybook coverage is missing"
      ],
      "rules": [
        "Only a direct Storybook story target counts as documented component truth",
        "An exported component without direct Storybook coverage is a documentation governance gap",
        "A custom product implementation of an existing public component is a design-system bypass",
        "A product-only variant or state missing from Storybook is a variant or state governance gap"
      ]
    },
    "component_governance": {
      "usage_rules": [
        "Use public central-library components whenever an approved equivalent exists",
        "Use the highest suitable abstraction level available: template, organism, molecule, then atom",
        "Public visual components are incomplete until they have direct Storybook documentation",
        "Public subcomponents and provider-style exports must be documented directly or through explicit usage guidance"
      ],
      "preferred_patterns": [
        "Navigation should prefer Breadcrumbs, TabBar, Tabs, and Drawer",
        "Forms should prefer Input, Select, Autocomplete, MultiSelect, Radio, Switch, CheckBox, DatePicker, and FormField",
        "Actions should prefer documented Button patterns",
        "Content display should prefer Table, DataTable, CustomDataGrid, Accordion, KeyValue, ListItem, and SearchBar",
        "Feedback should prefer CircularProgress, LinearProgress, SnackBar, Modal, ConfirmationModal, ErrorTemplate, and BaseErrorTemplate"
      ]
    },
    "token_and_variant_rules": {
      "token_rules": [
        "Spacing must follow the library spacing function: 0.25rem multiplied by factor",
        "Radius must use the approved token scale: none, xs, sm, md, lg, xl, xl2, xl3, circular",
        "Typography must use the approved library font family: Noto Sans, sans-serif",
        "Typography must stay within approved font-size, font-weight, and line-height tokens",
        "Hardcoded spacing, radius, typography, or palette overrides are not allowed without explicit approval"
      ],
      "variant_rules": [
        "Allowed designVariant values use variants plain, outlined, soft, solid",
        "Allowed designVariant sizes are sm, md, lg",
        "Allowed designVariant colors are primary, neutral, danger, success, warning",
        "Undocumented designVariant combinations are not allowed without approval"
      ]
    },
    "ux_rules": {
      "state_rules": [
        "Relevant public component states must be complete and usable: default, selected or active, expanded or collapsed, disabled, loading, empty, success, error, and meaningful hover or focus states",
        "A Storybook-documented state must behave consistently in product when the same component is used in the same context",
        "A missing expected state for a public component is a UX consistency issue"
      ],
      "clarity_rules": [
        "Text should use Typography or FormattedTypography patterns rather than arbitrary typographic styling",
        "Core interaction patterns such as search, selection, stepper progression, modal flows, bottom sheets, and confirmations must preserve documented behavior",
        "A custom pattern used where a documented library pattern exists is both a UX inconsistency and a design-system inconsistency"
      ]
    },
    "observer_rules": {
      "classification": [
        "Documented library component",
        "Undocumented public library export",
        "Non-library custom component"
      ],
      "capture": [
        "Screenshots",
        "DOM structure",
        "Computed styles",
        "Accessible names and labels",
        "Interaction states",
        "Viewport size",
        "Theme context where relevant"
      ],
      "validation": [
        "Map live components back to the public API whenever possible",
        "Validate documented components against Storybook, theme tokens, and approved variants or states",
        "Validate undocumented public exports with rule-based checks and flag governance gaps",
        "Validate token usage, variant grammar, relevant state behavior, and responsive behavior",
        "Label findings as documented mismatch, documented match, documentation gap, variant or state gap, design-system bypass, rule-based finding, or heuristic supplement"
      ],
      "output": [
        "Component name",
        "Storybook status",
        "Issue category",
        "Severity",
        "Confidence",
        "Evidence",
        "Recommended next action"
      ]
    }
  },
  "automation_config": {
    "non_blocking": true,
    "expected_font_family": "Noto Sans",
    "spacing_step_px": 4,
    "spacing_tolerance_px": 1,
    "radius_scale_px": [0, 2, 4, 8, 12, 16, 20, 24, 1000],
    "radius_tolerance_px": 1,
    "max_elements_per_audit": 40,
    "observer_selectors": {
      "interactive": "button, [role='button'], [role='tab'], input, textarea, select",
      "images": "img",
      "external_links": "a[target='_blank']"
    },
    "component_detection_scope_selector": "button, [role='button'], [role='tab'], [role='tablist'], [role='dialog'], [role='grid'], [role='table'], input, textarea, select, nav[aria-label*='breadcrumb' i], [class*='MuiCard-root'], [class*='MuiChip-root'], [class*='MuiAccordion-root'], [class*='MuiAvatar-root'], [class*='MuiListItemButton-root'], [class*='MuiLinearProgress-root'], [class*='MuiCircularProgress-root']",
    "component_detection_rules": [
      {
        "component_name": "SearchBar",
        "selector": "input[placeholder*='search' i], input[type='search'], [role='searchbox']",
        "priority": 120,
        "confidence_score": 0.95,
        "allow_variant_mix": false
      },
      {
        "component_name": "Autocomplete",
        "selector": "input[role='combobox'][aria-autocomplete], [class*='MuiAutocomplete-root'] input",
        "priority": 115,
        "confidence_score": 0.92,
        "allow_variant_mix": false
      },
      {
        "component_name": "Select",
