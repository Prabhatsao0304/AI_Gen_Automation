# ─── Product URLs ───────────────────────────────────────────
FMT_OS_URL=https://your-fmt-os-url.com
FMT_PRO_URL=https://your-fmt-pro-url.com

# ─── Credentials ────────────────────────────────────────────
USERNAME=your_email@company.com
PASSWORD=your_password

# ─── Browser Settings ───────────────────────────────────────
# Options: chromium | firefox | webkit
BROWSER=chromium

# Set to true to run without a visible browser window
HEADLESS=false

# ─── Timeouts (ms) ──────────────────────────────────────────
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# ─── Reporting ──────────────────────────────────────────────
REPORT_DIR=reports
SCREENSHOT_DIR=screenshots
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── Self-heal (fallback locators) ─────────────────────────
# true = console warning when a non-primary strategy wins
SELF_HEAL_LOG=false
# false = disable reports/self-heal-events.jsonl drift log (default: enabled)
SELF_HEAL_DRIFT_LOG=
